---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Circuit Collision — Biobod.net" description="Circuit Collision: a project under the Biobod umbrella.">

  <nav class="topbar">
    <div class="topbar-left">
      <a href="/mixnest"    class="tb-link tb-gray">MixNest</a>
      <a href="/"           class="tb-link tb-purple">Biobod.net</a>
      <a href="/mixnestfm"  class="tb-link tb-green">MixNestFM</a>
    </div>
    <button class="theme-btn" id="themeBtn">
      <span id="themeIcon">☀️</span>
      <span id="themeLabel">Light Mode</span>
    </button>
  </nav>

  <main class="page">
    <div class="uc-hero">
      <div class="uc-icon">⚡</div>
      <h1>Circuit Collision</h1>
      <p>Everything Circuit Collision — a project in the works.</p>
      <p>This page is currently under development. Come back later to see the final result!</p>
      <div class="uc-badge"><span class="pulse-dot"></span> Under Development</div>
    </div>
    <footer class="uc-footer">
      <p>© 2025 Circuit Collision · Part of <a href="/">Biobod.net</a></p>
    </footer>
  </main>

</BaseLayout>
